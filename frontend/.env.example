# Frontend (Vercel) environment — copy to .env.local for local dev,
# and set the same keys in the Vercel project dashboard for production.

# Base URL of the deployed backend (no trailing slash).
# Local dev: http://localhost:8000
# Production: https://<your-backend>.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# Deployed subscription contract address (leave empty = everyone on free tier).
NEXT_PUBLIC_SUBSCRIPTION_CONTRACT_ADDRESS=

# Base Sepolia USDC (used for the subscription payment flow).
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
