DATABASE_URL=postgresql+psycopg2://sosolens:sosolens@localhost:5432/sosolens

SOSOVALUE_API_KEY=
ANTHROPIC_API_KEY=       # default provider
OPENAI_API_KEY=          # optional
OPENROUTER_API_KEY=      # optional — routes to 100+ models
OPENROUTER_MODEL=z-ai/glm-4.5-air:free   # optional, override default model
GEMINI_API_KEY=          # optional
AI_PROVIDERS=anthropic   # comma-sep priority order: anthropic,openai,openrouter,gemini

# Wave 2 — Subscription contract
SUBSCRIPTION_CONTRACT_ADDRESS=   # set after deploy: forge script script/Deploy.s.sol --rpc-url $RPC_URL --broadcast
RPC_URL=https://sepolia.base.org # Base Sepolia RPC
PRIVATE_KEY=                     # deployer wallet private key

# Cloudflare Worker cache (optional — enables edge caching)
CACHE_WORKER_URL=    # e.g. https://sosolens-cache.youraccount.workers.dev
CACHE_PUSH_SECRET=   # random string; must match PUSH_SECRET Worker secret
